# Use the variant built specifically for huge context
FROM qwen2.5-coder:14b

# Set your target context window
PARAMETER num_ctx 153600

# Keep temperature low for high-accuracy coding
PARAMETER temperature 0.2

# Force all 48 layers to the GPU
PARAMETER num_gpu 48

# Official stop tokens for Qwen
PARAMETER stop "<|file_separator|>"
PARAMETER stop "<|im_end|>"